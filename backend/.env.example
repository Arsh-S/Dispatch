OPENROUTER_API_KEY=your-openrouter-key
BL_API_KEY=your-blaxel-key
GITHUB_TOKEN=your-github-pat
JWT_SECRET=super-secret-key-123

# Datadog integration (optional — enables log forwarding + read proxy)
# DATADOG_API_KEY=         # Required to enable any Datadog integration
# DD_APPLICATION_KEY=      # Required for read path (middleware queries Datadog on behalf of agents)
# DD_SITE=datadoghq.com   # Datadog site (default: datadoghq.com)
# DD_ENV=development       # Environment tag (default: dispatch)
# DD_SERVICE=dispatch      # Service name tag (default: dispatch-scanner)
