OPENROUTER_API_KEY=your-openrouter-key
BL_API_KEY=your-blaxel-key
GITHUB_TOKEN=your-github-pat
GITHUB_REPO=owner/repo

# PR/commit identity — PRs appear as "Dispatch Agent" instead of your account
# Use a GitHub App token (not a personal PAT) so the PR author shows as "Dispatch[bot]"
# See docs/github-bot-identity.md for setup. Run: pnpm setup:github-app --identity
DISPATCH_GIT_AUTHOR_NAME=Dispatch Agent
DISPATCH_GIT_AUTHOR_EMAIL=dispatch-agent@dispatch.ai

# GitHub App (optional — for setup:github-app script to generate GITHUB_TOKEN)
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY=   # or GITHUB_APP_PRIVATE_KEY_PATH=./private-key.pem
JWT_SECRET=super-secret-key-123

# Slack Agent (required for pnpm slack)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_NOTIFICATION_CHANNEL=     # Optional — channel for notifications
AGENT_NAME=Dispatch Security Agent
DISPATCH_TARGET_DIR=./sample-app  # Target directory for "scan" command
DISPATCH_TARGET_PORT=3344        # Port for target app (default 3344). Use when frontend uses 3000 to avoid conflict.
JUICE_SHOP_URL=                  # Optional — for Juice Shop commands

# Linear Demo Integration
LINEAR_API_KEY=           # Create at https://linear.app/settings/api
LINEAR_TEAM_ID=          # Team UUID from Linear (Settings → Team)
LINEAR_WORKSPACE_URL=    # Optional: https://your-workspace.linear.app
DISPATCH_FIX_URL=        # Optional: https://your-dispatch-api.com/fix (for "Run Dispatch Fixer" link in issues)

# BrowserBase (optional — for UI Worker / headed browser testing via MCP)
BROWSERBASE_API_KEY=     # Get from https://www.browserbase.com/overview
GEMINI_API_KEY=          # Optional — for Stagehand AI (default: google/gemini-2.5-flash-lite)

# Datadog Integration (optional — all forwarding is no-op when DATADOG_API_KEY is absent)
DATADOG_API_KEY=         # Required for Datadog forwarding
DD_APPLICATION_KEY=      # Optional — enables reading logs back from Datadog
DD_SITE=datadoghq.com    # Optional — Datadog site (default: datadoghq.com)
DD_ENV=development       # Optional — environment tag (default: dispatch)
DD_SERVICE=dispatch      # Optional — service name (default: dispatch-scanner)
